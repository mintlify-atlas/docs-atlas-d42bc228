  "keyFeatures": [
    "Multi-service microarchitecture for password management backend",
    "RESTful API with comprehensive vault, organization, and user management",
    "Enterprise SSO and SCIM provisioning support",
    "Secrets Manager for developer credentials and API keys",
    "Docker-based deployment with multi-database support (SQL Server, PostgreSQL, MySQL)",
    "End-to-end encryption with zero-knowledge architecture",
    "Real-time notifications via SignalR",
    "Event logging and auditing system",
    "Multi-tenant organization management with role-based access control"
  ],
  "publicApiSurface": [
    "POST /identity/connect/token - Authentication",
    "GET /accounts/profile - User profile",
    "POST /accounts/register - User registration",
    "GET /ciphers - List vault items",
    "POST /ciphers - Create vault item",
    "PUT /ciphers/{id} - Update vault item",
    "DELETE /ciphers/{id} - Delete vault item",
    "GET /sync - Sync vault data",
    "GET /organizations/{id} - Get organization",
    "POST /organizations - Create organization",
    "GET /organizations/{id}/users - List organization users",
    "POST /organizations/{id}/users/invite - Invite user",
    "GET /collections - List collections",
    "POST /collections - Create collection",
    "GET /api/public/members - Public API: List members",
    "POST /api/public/members - Public API: Create member",
    "GET /secrets-manager/secrets - List secrets",
    "POST /secrets-manager/secrets - Create secret",
    "GET /secrets-manager/projects - List projects",
    "POST /secrets-manager/service-accounts - Create service account",
    "POST /two-factor/get-authenticator - Get 2FA authenticator",
    "GET /folders - List folders",
    "POST /emergency-access - Emergency access requests"
  ]
